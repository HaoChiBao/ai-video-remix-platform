# =============================================================================
# Backend API (Express) — all app API calls use this base URL via lib/api/http.ts
# =============================================================================
# Browser (client components): required. Full origin, no trailing slash.
# Change .env.local and rebuild/restart Next for production.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Next.js server (RSC, server fetches): optional override when the server should
# call a different host than the browser (e.g. Docker internal http://api:8080).
# If omitted, API_URL falls back to NEXT_PUBLIC_API_URL.
API_URL=http://127.0.0.1:8080

# =============================================================================
# Third-party embed (Vidking) — must match server VIDKING_ORIGIN for probes
# =============================================================================
NEXT_PUBLIC_VIDKING_ORIGIN=https://www.vidking.net
